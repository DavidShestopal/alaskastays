---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: 'Authentic Alaska',
    description: 'Every property is owner-operated with genuine roots in Alaska. No corporate chains, no cookie-cutter listings — just real people sharing real places.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>',
  },
  {
    title: 'Stewardship',
    description: 'We believe in preserving the wilderness that makes Alaska special. Our properties practice sustainable tourism and leave-no-trace principles.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.25 2.25 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438c.08.474.49.821.97.821.846 0 1.598.542 1.865 1.345l.215.643m5.276-3.67a9.012 9.012 0 01-5.276 3.67m0 0a9 9 0 01-10.275-4.835M15.898 19.51l-1.177-3.14"/></svg>',
  },
  {
    title: 'Direct Connection',
    description: 'When you book direct, you connect directly with your host. Better prices, more flexibility, and a personal touch that platforms can\'t replicate.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>',
  },
];

const stats = [
  { value: '2', label: 'Handpicked Properties' },
  { value: '4.9', label: 'Average Rating' },
  { value: '300+', label: 'Happy Guests' },
  { value: '1', label: 'Region: Palmer, AK' },
];
---

<Layout
  title="About Us — Alaska Stays"
  description="Learn about the team behind Alaska Stays — lifelong Alaskans passionate about sharing the Last Frontier with travelers from around the world."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-44 lg:pt-40 lg:pb-52 bg-evergreen overflow-x-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2e4d3d 0%, #22382d 50%, #1a2b22 100%);"></div>
      <div class="absolute top-16 right-12 w-20 h-20 dot-pattern opacity-10"></div>

      <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
        <span class="label-sm text-marigold tracking-[0.2em] mb-4 block" data-reveal>About Us</span>
        <h1 class="heading-xl text-white text-5xl lg:text-7xl mb-6" data-reveal>
          Born in<br />
          <span class="text-marigold italic">Alaska.</span>
        </h1>
        <p class="text-white/50 text-lg font-light max-w-xl leading-relaxed" data-reveal>
          We're a small team of lifelong Alaskans on a mission to help travelers
          experience the real Alaska — not the tourist-trap version.
        </p>
      </div>

      <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
        <img src="/images/treeline-silhouette.svg" alt="" role="presentation" class="w-full block" />
      </div>
    </section>

    <!-- Our Story -->
    <section class="py-20 lg:py-32 bg-river-rock">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div data-reveal>
            <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Our Story</span>
            <h2 class="heading-lg text-black text-3xl lg:text-5xl mb-6">
              From a Single Cabin to<br />
              <span class="text-marigold italic">Alaska's Best.</span>
            </h2>
            <div class="space-y-4 text-black/70 text-[0.95rem] font-light leading-relaxed">
              <p>
                It started with a love for Alaska and a belief that visitors deserve more than generic hotels.
                We watched too many friends visit and miss out on everything that makes this place extraordinary.
                So we opened our own doors — and guests started coming back year after year.
              </p>
              <p>
                Alaska Stays was born from a simple philosophy: authentic hospitality, immaculate spaces,
                and real local knowledge. Every property is personally vetted and owner-operated — no corporate
                chains, no cookie-cutter listings.
              </p>
              <p>
                Based in Palmer, Alaska, our properties offer stunning views of the Matanuska Valley with
                easy access to glaciers, wildlife, and the northern lights. The mission is simple: help every
                guest experience the Alaska that locals love.
              </p>
            </div>
          </div>

          <div class="relative rounded-2xl overflow-hidden aspect-[4/5]" data-reveal-scale>
            <img
              src="/images/team.avif"
              alt="The Alaska Stays team"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute -bottom-4 -right-4 w-24 h-24 border border-marigold/20 rounded-full"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="relative py-16 bg-evergreen overflow-x-hidden">
      <div class="absolute top-0 left-0 right-0 -translate-y-[99%] pointer-events-none">
        <img src="/images/treeline-silhouette-dark.svg" alt="" role="presentation" class="w-full block" />
      </div>

      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8" data-stagger>
          {stats.map((stat) => (
            <div class="text-center" data-reveal>
              <span class="heading-xl text-marigold text-4xl lg:text-5xl block mb-2">{stat.value}</span>
              <span class="text-white/40 text-sm font-light">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Values -->
    <section class="py-20 lg:py-32 bg-river-rock">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <div class="text-center mb-16" data-reveal>
          <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Our Values</span>
          <h2 class="heading-lg text-black text-3xl lg:text-5xl">
            What We <span class="text-marigold italic">Stand For.</span>
          </h2>
        </div>

        <div class="grid lg:grid-cols-3 gap-8" data-stagger>
          {values.map((value) => (
            <div class="group bg-white/40 rounded-2xl p-8 lg:p-10 hover:bg-white/70 transition-all duration-500" data-reveal>
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-evergreen/10 text-evergreen mb-6 group-hover:bg-marigold/15 group-hover:text-marigold transition-all duration-500">
                <Fragment set:html={value.icon} />
              </div>
              <h3 class="font-bold text-xl text-black mb-3">{value.title}</h3>
              <p class="text-slate-grey text-sm font-light leading-relaxed">{value.description}</p>
              <div class="w-8 h-[2px] bg-marigold/40 mt-6 group-hover:w-16 transition-all duration-500"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 lg:py-28 bg-river-rock">
      <div class="max-w-2xl mx-auto px-6 lg:px-10 text-center" data-reveal>
        <h2 class="heading-lg text-black text-3xl lg:text-5xl mb-6">
          Ready to Experience<br />
          <span class="text-marigold italic">Real Alaska?</span>
        </h2>
        <p class="text-slate-grey text-[0.95rem] font-light mb-10 max-w-md mx-auto leading-relaxed">
          Browse our handpicked properties and start planning the
          Alaskan adventure you've been dreaming about.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/properties" class="btn-primary">
            Browse Properties
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a href="/contact" class="btn-dark">Contact Us</a>
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
