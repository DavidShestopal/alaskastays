---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const faqs = [
  {
    q: "What's the difference between Juniper Tree and Valley View?",
    a: "Juniper Tree is a cozy 2-bedroom cabin that sleeps 6, perfect for couples or small families. Valley View is a larger 3-bedroom cabin sleeping 9, ideal for groups or families wanting more space. Both are in Palmer and feature hot tubs and saunas.",
  },
  {
    q: "How do I get to the properties from Anchorage?",
    a: "Both cabins are located in Palmer, about a 45-minute drive from Anchorage. The route follows the scenic Glenn Highway with mountain views the entire way. We'll send detailed directions after booking.",
  },
  {
    q: "Do the cabins have hot tubs and saunas?",
    a: "Yes! Juniper Tree has a hot tub and barrel sauna on the deck with panoramic mountain views. Valley View features a hot tub and cedar sauna. Both are available year-round.",
  },
  {
    q: "What's the best time to visit Palmer?",
    a: "Summer (June-August) is great for hiking, fishing, and long daylight hours. Winter (September-March) brings northern lights, snow activities, and a peaceful atmosphere. Each season has its own magic.",
  },
  {
    q: "Is there Wi-Fi and cell service at the cabins?",
    a: "Both properties have wireless internet. Cell service in Palmer is generally good, though coverage can vary depending on your carrier. We recommend downloading offline maps just in case.",
  },
  {
    q: "Can I book directly instead of through Airbnb?",
    a: "Absolutely — that's what we're here for! Booking direct through Alaska Stays saves you 10-20% compared to third-party platforms and gives you direct communication with your host.",
  },
];
---

<Layout
  title="Contact Us — Alaska Stays"
  description="Get in touch with the Alaska Stays team. We're here to help you plan the perfect Alaskan getaway."
>
  <Header />
  <main>
    <!-- Hero -->
    <section
      class="relative pt-32 pb-44 lg:pt-40 lg:pb-52 bg-evergreen overflow-hidden"
    >
      <div
        class="absolute inset-0"
        style="background: linear-gradient(135deg, #1a2b22 0%, #22382d 50%, #2e4d3d 100%);"
      >
      </div>
      <div class="absolute top-20 right-16 w-24 h-24 dot-pattern opacity-10">
      </div>

      <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
        <span
          class="label-sm text-marigold tracking-[0.2em] mb-4 block"
          data-reveal>Contact Us</span
        >
        <h1 class="heading-xl text-white text-5xl lg:text-7xl mb-6" data-reveal>
          Let's<br />
          <span class="text-marigold italic">Connect.</span>
        </h1>
        <p
          class="text-white/50 text-lg font-light max-w-lg leading-relaxed"
          data-reveal
        >
          Questions about a property? Need help planning your trip? Our
          Alaska-based team is here to help.
        </p>
      </div>

      <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
        <img
          src="/images/treeline-silhouette.svg"
          alt=""
          role="presentation"
          class="w-full block"
        />
      </div>
    </section>

    <!-- Contact Methods + Form -->
    <section class="py-16 lg:py-24 bg-river-rock">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <!-- Contact Form -->
        <div class="max-w-2xl mx-auto">
          <div data-reveal>
            <span class="label-sm text-marigold tracking-[0.2em] mb-4 block"
              >Send a Message</span
            >
            <h2 class="heading-lg text-black text-3xl lg:text-4xl mb-4">
              We'd Love to<br />
              <span class="text-marigold italic">Hear From You.</span>
            </h2>
            <p class="text-slate-grey text-sm font-light leading-relaxed mb-8">
              Whether you're looking for property recommendations, have
              questions about a booking, or want to list your property with us —
              drop us a line.
            </p>

            <form id="contact-form" action="https://formspree.io/f/mzdaqrry" method="POST" class="space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label
                    class="label-sm text-black/50 block mb-2"
                    style="font-size:0.65rem;">First Name</label
                  >
                  <input
                    type="text"
                    name="firstName"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-white/60 border border-black/10 text-sm font-medium text-black outline-none focus:border-marigold/50 focus:bg-white transition-all duration-300 placeholder-black/25"
                    placeholder="Your first name"
                  />
                </div>
                <div>
                  <label
                    class="label-sm text-black/50 block mb-2"
                    style="font-size:0.65rem;">Last Name</label
                  >
                  <input
                    type="text"
                    name="lastName"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-white/60 border border-black/10 text-sm font-medium text-black outline-none focus:border-marigold/50 focus:bg-white transition-all duration-300 placeholder-black/25"
                    placeholder="Your last name"
                  />
                </div>
              </div>

              <div>
                <label
                  class="label-sm text-black/50 block mb-2"
                  style="font-size:0.65rem;">Email</label
                >
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full px-4 py-3.5 rounded-xl bg-white/60 border border-black/10 text-sm font-medium text-black outline-none focus:border-marigold/50 focus:bg-white transition-all duration-300 placeholder-black/25"
                  placeholder="your@email.com"
                />
              </div>

              <div>
                <label
                  class="label-sm text-black/50 block mb-2"
                  style="font-size:0.65rem;">Topic</label
                >
                <select
                  name="topic"
                  class="w-full px-4 py-3.5 rounded-xl bg-white/60 border border-black/10 text-sm font-medium text-black outline-none focus:border-marigold/50 focus:bg-white transition-all duration-300 cursor-pointer"
                >
                  <option value="">Select a topic...</option>
                  <option>Booking Inquiry</option>
                  <option>Property Question</option>
                  <option>Trip Planning Help</option>
                  <option>List My Property</option>
                  <option>Partnership Opportunity</option>
                  <option>General Question</option>
                </select>
              </div>

              <div>
                <label
                  class="label-sm text-black/50 block mb-2"
                  style="font-size:0.65rem;">Message</label
                >
                <textarea
                  rows="5"
                  name="message"
                  required
                  class="w-full px-4 py-3.5 rounded-xl bg-white/60 border border-black/10 text-sm font-medium text-black outline-none focus:border-marigold/50 focus:bg-white transition-all duration-300 placeholder-black/25 resize-none"
                  placeholder="Tell us how we can help..."></textarea>
              </div>

              <div class="flex justify-end">
                <button type="submit" class="btn-primary !py-4 !px-10">
                  Send Message
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"
                    ></path>
                  </svg>
                </button>
              </div>
            </form>

            <!-- Success/Error messages -->
            <div id="contact-success" class="hidden mt-6 p-6 rounded-xl bg-evergreen/10 border border-evergreen/20 text-center">
              <p class="text-evergreen font-semibold mb-1">Message sent!</p>
              <p class="text-slate-grey text-sm font-light">We'll get back to you within 24 hours.</p>
            </div>
            <p id="contact-error" class="hidden mt-4 text-red-500 text-sm">Something went wrong. Please try again or email us directly.</p>

            <script>
              document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                const form = e.target;
                const btn = form.querySelector('button[type="submit"]');
                const btnText = btn.innerHTML;
                btn.innerHTML = 'Sending...';
                btn.disabled = true;

                try {
                  const res = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'Accept': 'application/json' },
                  });
                  if (res.ok) {
                    form.classList.add('hidden');
                    document.getElementById('contact-success')?.classList.remove('hidden');
                  } else {
                    document.getElementById('contact-error')?.classList.remove('hidden');
                    btn.innerHTML = btnText;
                    btn.disabled = false;
                  }
                } catch {
                  document.getElementById('contact-error')?.classList.remove('hidden');
                  btn.innerHTML = btnText;
                  btn.disabled = false;
                }
              });
            </script>
          </div>
        </div>

        <!-- FAQ -->
        <div class="max-w-2xl mx-auto mt-20" data-reveal>
          <span class="label-sm text-marigold tracking-[0.2em] mb-4 block text-center"
            >Common Questions</span
          >
          <h2 class="heading-lg text-black text-3xl lg:text-4xl mb-8 text-center">
            Quick <span class="text-marigold italic">Answers.</span>
          </h2>

          <div class="space-y-4">
            {
              faqs.map((faq) => (
                <details class="group bg-white/40 rounded-xl border border-black/[0.04] overflow-hidden">
                  <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
                    <span class="text-sm font-semibold text-black pr-4">
                      {faq.q}
                    </span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-5 h-5 text-slate-grey shrink-0 transition-transform duration-300 group-open:rotate-45"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 4.5v15m7.5-7.5h-15"
                      />
                    </svg>
                  </summary>
                  <div class="px-5 pb-5">
                    <p class="text-slate-grey text-sm font-light leading-relaxed">
                      {faq.a}
                    </p>
                  </div>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Treeline transition into map section -->
    <div class="relative pointer-events-none">
      <img
        src="/images/treeline-silhouette-dark.svg"
        alt=""
        role="presentation"
        class="w-full block"
      />
    </div>

    <!-- Map placeholder -->
    <section
      class="relative bg-evergreen-dark pt-16 lg:pt-24 pb-20 lg:pb-28"
    >

      <div class="max-w-[1400px] mx-auto px-6 lg:px-10 text-center">
        <h2 class="heading-md text-white text-2xl mb-3" data-reveal>
          Based in <span class="text-marigold italic">Palmer, Alaska</span>
        </h2>
        <p class="text-white/40 text-sm font-light mb-10" data-reveal>
          Gateway to the Matanuska Valley and Alaska's best adventures
        </p>

        <div
          class="relative rounded-2xl overflow-hidden aspect-[2/1] max-w-4xl mx-auto"
          data-reveal-scale
        >
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d30361.26999977678!2d-149.15918514872408!3d61.601221252951404!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x56c91de4eb932b0b%3A0xbe26a87be78ddd50!2sPalmer%2C%20AK%2099645!5e0!3m2!1sen!2sus!4v1773868265366!5m2!1sen!2sus"
            class="absolute inset-0 w-full h-full border-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
