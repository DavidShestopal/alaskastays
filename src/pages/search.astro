---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = false;
---

<Layout title="Search Properties — Alaska Stays" description="Search available cabins, lodges, and retreats across Alaska. Check availability and book direct.">
  <Header />
  <main>
    <section class="pt-28 pb-16 bg-river-rock" style="min-height: calc(100vh - 80px);">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-grey mb-8">
          <a href="/" class="hover:text-marigold transition-colors">Home</a>
          <span>/</span>
          <span class="text-black font-medium">Search</span>
        </nav>

        <!-- Hospitable Search Results Widget -->
        <div id="search-results-widget">
          <script is:inline src="https://hospitable.b-cdn.net/direct-property-search-widget/hospitable-search-widget.prod.js"></script>
          <hospitable-direct-mps
            identifier="d2e62d05-ccfe-48b6-b6ae-dbdd9df20e23"
            type="custom"
            style="--hospitable-primary-color: #22382d; --hospitable-secondary-color: #e2ad37;"
          ></hospitable-direct-mps>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  // Keep the section tall enough for the dynamically-rendered widget
  (function() {
    var container = document.getElementById('search-results-widget');
    if (!container) return;
    var section = container.closest('section');
    if (!section) return;
    var hospEl = container.querySelector('hospitable-direct-mps');

    function adjustHeight() {
      // Measure the true content height including shadow DOM internals
      var contentH = container.scrollHeight;
      // Also check inside shadow root for the real rendered height
      if (hospEl && hospEl.shadowRoot) {
        var inner = hospEl.shadowRoot.querySelector('.search-results-container, .properties-container, [class*="container"]');
        if (inner) {
          contentH = Math.max(contentH, inner.scrollHeight + hospEl.offsetTop);
        }
        // Fallback: measure all children in shadow root
        var kids = hospEl.shadowRoot.children;
        var maxBottom = 0;
        for (var i = 0; i < kids.length; i++) {
          if (kids[i].nodeType === 1) {
            var rect = kids[i].getBoundingClientRect();
            var bottom = rect.bottom + window.scrollY;
            if (bottom > maxBottom) maxBottom = bottom;
          }
        }
        if (maxBottom > 0) {
          var sectionTop = section.getBoundingClientRect().top + window.scrollY;
          contentH = Math.max(contentH, maxBottom - sectionTop + 200);
        }
      }
      var viewportMin = window.innerHeight - 80;
      section.style.minHeight = Math.max(contentH + 200, viewportMin) + 'px';
    }

    // Watch for widget size changes (cards loading in)
    var ro = typeof ResizeObserver !== 'undefined' ? new ResizeObserver(adjustHeight) : null;
    if (ro) ro.observe(container);

    // Also try to observe inside shadow DOM once it's available
    function observeShadow() {
      if (hospEl && hospEl.shadowRoot) {
        if (ro) ro.observe(hospEl);
        var inner = hospEl.shadowRoot.firstElementChild;
        if (inner && ro) ro.observe(inner);
        return true;
      }
      return false;
    }

    // Poll while widget initializes + observe shadow when ready
    var polls = 0;
    var pollTimer = setInterval(function() {
      adjustHeight();
      observeShadow();
      if (++polls > 60) clearInterval(pollTimer);
    }, 500);
  })();

  // Theme the Hospitable search widget on the search page
  function themeSearchWidget() {
    const widget = document.querySelector('#search-results-widget hospitable-direct-mps');
    if (!widget || !widget.shadowRoot) {
      setTimeout(themeSearchWidget, 200);
      return;
    }
    const sr = widget.shadowRoot;
    if (sr.querySelector('#search-widget-theme')) return;

    const style = document.createElement('style');
    style.id = 'search-widget-theme';
    style.textContent = `
      .search-bar-container {
        padding: 0 !important;
        width: 100% !important;
        margin-left: 0 !important;
        left: 0 !important;
        margin-bottom: 24px !important;
        background: transparent !important;
      }

      input, select, .location-dropdown {
        border-radius: 10px !important;
        font-family: 'Montserrat', system-ui, sans-serif !important;
        font-size: 0.9rem !important;
      }

      input:focus, select:focus {
        box-shadow: 0 0 0 2px rgba(226, 173, 55, 0.5) !important;
        border-color: #e2ad37 !important;
      }

      .search-btn {
        background: #e2ad37 !important;
        color: #191b22 !important;
        border-radius: 10px !important;
        font-family: 'Montserrat', system-ui, sans-serif !important;
        font-weight: 700 !important;
        font-size: 0.9rem !important;
      }

      .search-btn:hover {
        filter: brightness(110%) !important;
      }

      .property {
        border-radius: 16px !important;
        overflow: hidden !important;
      }

      .property-title {
        font-family: 'Montserrat', system-ui, sans-serif !important;
      }

      .book-now {
        background: #e2ad37 !important;
        color: #191b22 !important;
        border-radius: 9999px !important;
        font-family: 'Montserrat', system-ui, sans-serif !important;
        font-weight: 700 !important;
      }
    `;
    sr.prepend(style);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', themeSearchWidget);
  } else {
    themeSearchWidget();
  }

  // Intercept property clicks — map Hospitable widget titles to our property slugs.
  // The widget shows public_name (listing title) but our slugs come from hp.name (internal name).
  var titleToSlug = {};

  // Fetch property data to build title-to-slug mapping
  fetch('/api/properties')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.data) {
        d.data.forEach(function(p) {
          // Map both tagline (public_name) and title (internal name) to slug
          if (p.tagline) titleToSlug[p.tagline.trim().toLowerCase()] = p.slug;
          if (p.title) titleToSlug[p.title.trim().toLowerCase()] = p.slug;
        });
      }
    })
    .catch(function() {});

  // Capture clicks via composedPath() which crosses shadow DOM
  document.addEventListener('click', function(e) {
    var path = e.composedPath();
    var propertyCard = null;
    for (var i = 0; i < path.length; i++) {
      var el = path[i];
      if (el.classList && el.classList.contains('property') && !el.classList.contains('skeleton')) {
        propertyCard = el;
        break;
      }
    }
    if (!propertyCard) return;

    var titleEl = propertyCard.querySelector('.property-title');
    if (!titleEl) return;

    var widgetTitle = titleEl.textContent.trim().toLowerCase();
    var slug = titleToSlug[widgetTitle];
    if (!slug) return; // No match — let default behavior happen

    e.stopPropagation();
    e.preventDefault();

    var params = new URLSearchParams(window.location.search);
    var url = '/properties/' + slug;
    if (params.toString()) {
      url += '?' + params.toString();
    }
    window.location.href = url;
  }, true);

  // Fallback — intercept any navigation to /null
  (function() {
    var origAssign = window.location.assign;
    var origReplace = window.location.replace;

    function checkNullNav(url) {
      if (typeof url === 'string' && (url === '/null' || url.startsWith('/null?') || url.startsWith('/null#'))) {
        return true;
      }
      return false;
    }

    window.location.assign = function(url) {
      if (checkNullNav(url)) {
        console.warn('[AlaskaStays] Blocked navigation to /null — property URL not configured in Hospitable.');
        return;
      }
      return origAssign.call(window.location, url);
    };

    window.location.replace = function(url) {
      if (checkNullNav(url)) {
        console.warn('[AlaskaStays] Blocked navigation to /null — property URL not configured in Hospitable.');
        return;
      }
      return origReplace.call(window.location, url);
    };
  })();
</script>
