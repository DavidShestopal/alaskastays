---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Newsletter from '../../components/Newsletter.astro';
import Footer from '../../components/Footer.astro';
import { getAllProperties } from '../../lib/hospitable';

export const prerender = false;

const allProperties = await getAllProperties();

const properties = allProperties;

const badgeLabels: Record<string, string> = {
  'guest-favorite': 'Guest Favorite',
  'superhost': 'Superhost',
  'new': 'New',
  'rare-find': 'Rare Find',
  'aurora': 'Aurora Viewing',
  'waterfront': 'Waterfront',
  'remote': 'Remote & Secluded',
  'pet-friendly': 'Pet Friendly',
};
---

<Layout
  title="Properties — Alaska Stays"
  description="Browse our handpicked collection of cabins, lodges, and retreats across Alaska's most breathtaking landscapes."
>
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="relative pt-32 pb-44 lg:pt-40 lg:pb-52 bg-evergreen overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #2e4d3d 0%, #22382d 40%, #1a2b22 100%);"></div>
      <div class="absolute top-16 right-12 w-24 h-24 dot-pattern opacity-10"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 border border-white/[0.04] rounded-full"></div>

      <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
        <span class="label-sm text-marigold tracking-[0.2em] mb-4 block" data-reveal>Our Properties</span>
        <h1 class="heading-xl text-white text-5xl lg:text-7xl mb-6" data-reveal>
          Find Your<br />
          <span class="text-marigold italic">Perfect Stay.</span>
        </h1>
        <p class="text-white/50 text-lg font-light max-w-lg leading-relaxed" data-reveal>
          Each property is personally vetted and owner-operated.
          Real Alaskan hospitality, not corporate rentals.
        </p>
      </div>

      <!-- Treeline divider -->
      <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
        <img src="/images/treeline-silhouette.svg" alt="" role="presentation" class="w-full block" />
      </div>
    </section>

    <!-- Properties Grid -->
    <section class="py-16 lg:py-24 bg-river-rock">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <!-- Results count -->
        <div class="mb-10" data-reveal>
          <p class="text-slate-grey text-sm font-light">
            <span class="text-black font-semibold">{properties.length} {properties.length === 1 ? 'property' : 'properties'}</span> in Palmer, Alaska
          </p>
        </div>

        <!-- Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-stagger>
          {properties.map((property) => (
            <a
              href={`/properties/${property.slug}`}
              class="group block rounded-3xl overflow-hidden bg-white/60 hover:bg-white/90 border border-black/[0.04] hover:border-marigold/20 transition-all duration-500 hover:shadow-xl hover:shadow-black/5 hover:-translate-y-1"
              data-reveal
            >
              <!-- Image -->
              <div class="relative aspect-[4/3] overflow-hidden">
                {property.coverImage ? (
                  <img
                    src={property.coverImage}
                    alt={property.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
                    style="background: linear-gradient(135deg, #2e4d3d 0%, #22382d 40%, #1a2b22 100%);"
                  ></div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>

                <!-- Badges -->
                {property.badges?.length > 0 && (
                  <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                    {property.badges.slice(0, 2).map((badge: string) => (
                      <span class="bg-white/90 backdrop-blur-sm text-black text-xs font-bold px-3 py-1 rounded-full">
                        {badgeLabels[badge] || badge}
                      </span>
                    ))}
                  </div>
                )}

                <!-- Property type -->
                <div class="absolute top-4 right-4">
                  <span class="bg-black/50 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">{property.propertyType}</span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-5 lg:p-6">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="font-sans font-bold text-lg text-black group-hover:text-evergreen transition-colors">
                    {property.title}
                  </h3>
                  {property.rating && (
                    <div class="flex items-center gap-1 shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-black" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                      </svg>
                      <span class="text-sm font-semibold text-black">{property.rating}</span>
                      <span class="text-sm text-slate-grey">({property.totalReviews})</span>
                    </div>
                  )}
                </div>

                <p class="text-slate-grey text-sm font-light mb-1">{property.location}</p>
                <p class="text-slate-grey/70 text-xs font-light mb-4">{property.tagline}</p>

                <div class="flex items-center justify-between pt-4 border-t border-black/[0.06]">
                  <div class="flex items-center gap-3 text-slate-grey text-xs">
                    <span>{property.guests} guests</span>
                    <span class="w-1 h-1 rounded-full bg-slate-grey/30"></span>
                    <span>{property.bedrooms} bed</span>
                    <span class="w-1 h-1 rounded-full bg-slate-grey/30"></span>
                    <span>{property.bathrooms} bath</span>
                  </div>
                  {property.basePrice && (
                    <span class="text-black font-bold">
                      <span class="text-slate-grey text-xs font-normal">From </span>${property.basePrice}<span class="text-slate-grey text-xs font-light">/night</span>
                    </span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  <Footer />
</Layout>
