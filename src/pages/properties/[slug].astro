---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Newsletter from '../../components/Newsletter.astro';
import Footer from '../../components/Footer.astro';
import { getPropertyBySlug } from '../../lib/hospitable';

export const prerender = false;

const { slug } = Astro.params;
const property = await getPropertyBySlug(slug as string);

if (!property) {
  return Astro.redirect('/properties');
}

const descriptionText = property.descriptionText || '';

const bookingWidgets: Record<string, { iframe: string; fallback: string }> = {
  'juniper-tree': {
    iframe: 'https://booking.hospitable.com/widget/a12d15c1-210e-4476-b940-322c92b4887a/893068',
    fallback: 'https://booking.hospitable.com/widget/a12d15c1-210e-4476-b940-322c92b4887a/893068',
  },
  'valley-view': {
    iframe: 'https://booking.hospitable.com/widget/a12d15c1-210e-4476-b940-322c92b4887a/1115840',
    fallback: 'https://booking.hospitable.com/widget/a12d15c1-210e-4476-b940-322c92b4887a/1115840',
  },
};

const widget = bookingWidgets[property.slug];

const badgeLabels: Record<string, string> = {
  'guest-favorite': 'Guest Favorite',
  'superhost': 'Superhost',
  'new': 'New',
  'rare-find': 'Rare Find',
  'aurora': 'Aurora Viewing',
  'waterfront': 'Waterfront',
  'remote': 'Remote & Secluded',
  'pet-friendly': 'Pet Friendly',
};

const checkInMethodLabels: Record<string, string> = {
  'keypad': 'Self Check-in (Keypad)',
  'lockbox': 'Self Check-in (Lockbox)',
  'smart-lock': 'Self Check-in (Smart Lock)',
  'host-greeting': 'Host Greeting',
  'building-staff': 'Building Staff',
};

const ruleLabels: Record<string, string> = {
  'no-smoking': 'No smoking',
  'no-pets': 'No pets',
  'pets-allowed': 'Pets allowed',
  'no-parties': 'No parties or events',
  'quiet-hours': 'Quiet hours 10PM - 8AM',
  'no-shoes': 'No shoes inside',
  'bear-safe': 'Bear-safe food storage required',
  'pack-out': 'Pack in / pack out trash',
  'fire-ban': 'No campfires during fire bans',
  'no-feeding': 'Respect wildlife - no feeding animals',
  'supervise-children': 'Children must be supervised near water',
};

// Build gallery array: API images first, fallback to cover image
const allImages: Array<{ src: string; alt: string }> = property.gallery?.length
  ? property.gallery
  : property.coverImage
    ? [{ src: property.coverImage, alt: property.title }]
    : [];
---

<Layout
  title={`${property.title} — Alaska Stays`}
  description={property.tagline || property.title}
>
  <Header />
  <main>
    <!-- Photo Gallery Hero -->
    <section class="pt-24 lg:pt-28 bg-river-rock">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-grey mb-6 pt-4">
          <a href="/" class="hover:text-marigold transition-colors">Home</a>
          <span>/</span>
          <a href="/properties" class="hover:text-marigold transition-colors">Properties</a>
          <span>/</span>
          <span class="text-black font-medium">{property.title}</span>
        </nav>

        <!-- Photo Grid (Airbnb-style 5-photo layout) -->
        <div
          id="photo-grid"
          class="grid grid-cols-1 lg:grid-cols-4 lg:grid-rows-2 gap-2 rounded-2xl overflow-hidden cursor-pointer group relative"
          data-images={JSON.stringify(allImages)}
        >
          <!-- Main large photo -->
          <div class="lg:col-span-2 lg:row-span-2 relative min-h-[300px] lg:min-h-[480px]" data-photo-index="0">
            {allImages[0] ? (
              <img
                src={allImages[0].src}
                alt={allImages[0].alt}
                class="absolute inset-0 w-full h-full object-cover group-hover:opacity-90 transition-opacity"
                loading="eager"
              />
            ) : (
              <>
                <div class="absolute inset-0 group-hover:opacity-90 transition-opacity" style="background: linear-gradient(135deg, #2e4d3d 0%, #22382d 50%, #1a2b22 100%);"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="text-white/30 text-sm">Cover Photo</span>
                </div>
              </>
            )}
          </div>
          <!-- 4 smaller photos -->
          {[1, 2, 3, 4].map((i) => (
            <div class="hidden lg:block relative min-h-[235px]" data-photo-index={i}>
              {allImages[i] ? (
                <img
                  src={allImages[i].src}
                  alt={allImages[i].alt}
                  class="absolute inset-0 w-full h-full object-cover group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              ) : (
                <>
                  <div class="absolute inset-0 group-hover:opacity-90 transition-opacity" style={`background: linear-gradient(${135 + i * 30}deg, #22382d 0%, #2e4d3d 100%);`}></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-white/30 text-sm">Photo {i + 1}</span>
                  </div>
                </>
              )}
            </div>
          ))}
          {allImages.length > 5 && (
            <button id="show-all-photos" class="absolute bottom-4 right-4 bg-white text-black text-sm font-semibold px-4 py-2 rounded-lg border border-black/20 hover:bg-white/90 transition-colors hidden lg:flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/>
              </svg>
              Show all {allImages.length} photos
            </button>
          )}
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="bg-river-rock py-10 lg:py-16">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <div class="grid lg:grid-cols-3 gap-10 lg:gap-16">
          <!-- Left Column (2/3) -->
          <div class="lg:col-span-2">
            <!-- Title & Stats -->
            <div class="mb-8" data-reveal>
              {property.badges?.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {property.badges.map((badge: string) => (
                    <span class="bg-marigold/15 text-marigold-dark text-xs font-bold px-3 py-1 rounded-full">
                      {badgeLabels[badge] || badge}
                    </span>
                  ))}
                </div>
              )}
              <h1 class="heading-lg text-black text-3xl lg:text-5xl mb-2">{property.title}</h1>
              <div class="flex flex-wrap items-center gap-2 text-sm text-slate-grey">
                {property.rating && (
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-black" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                    </svg>
                    <span class="text-black font-semibold">{property.rating}</span>
                    {property.totalReviews && <span>&middot; {property.totalReviews} reviews</span>}
                  </div>
                )}
                {property.location && (
                  <>
                    <span>&middot;</span>
                    <span>{property.location}</span>
                  </>
                )}
              </div>
            </div>

            <!-- Quick Stats Bar -->
            <div class="flex flex-wrap gap-6 py-6 border-y border-black/[0.08] mb-8" data-reveal>
              <div class="flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black/70" viewBox="0 0 32 32" aria-hidden="true" fill="currentColor"><path d="M16 1a6 6 0 1 1 0 12 6 6 0 0 1 0-12zm0 2a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM3 28a13 13 0 0 1 26 0zm2 0h22a11 11 0 0 0-22 0z"/></svg>
                <span class="text-black font-medium">{property.guests} guests</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black/70" viewBox="0 0 32 32" aria-hidden="true" fill="currentColor"><path d="M25 1a2 2 0 0 1 2 1.85V29h2v2H3v-2h2V3a2 2 0 0 1 1.85-2H7zm0 2H7v26h18zm-3 12a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                <span class="text-black font-medium">{property.bedrooms} bedrooms</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black/70" viewBox="0 0 32 32" aria-hidden="true" fill="currentColor"><path d="M28 16H4v-3a3 3 0 0 1 3-3h18a3 3 0 0 1 3 3zM8 8a2 2 0 0 1 2-2h3v4H8zm10-2h3a2 2 0 0 1 2 2v2h-5zM2 16h28v2H2zm2 4h24v2H6v4H4zm24 2v4h-2v-4z"/></svg>
                <span class="text-black font-medium">{property.beds} beds</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black/70" viewBox="0 0 32 32" aria-hidden="true" fill="currentColor"><path d="M7.5 2a4.5 4.5 0 0 1 4.47 4H14v2H8V6h1.95A2.5 2.5 0 0 0 5 6.34V16h26v2h-2v5a5 5 0 0 1-3 4.58V30h-2v-2H8v2H6v-2.42a5 5 0 0 1-3-4.34V18H1v-2h2V6.5A4.5 4.5 0 0 1 7.5 2zM27 18H5v5a3 3 0 0 0 2.65 2.98l.17.01L8 26h16a3 3 0 0 0 3-2.82V23z"/></svg>
                <span class="text-black font-medium">{property.bathrooms} baths</span>
              </div>
            </div>

            <!-- Highlights -->
            {property.highlights?.length > 0 && (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10" data-reveal>
                {property.highlights.map((h: any) => (
                  <div class="flex items-start gap-4 p-4 rounded-xl bg-white/40">
                    <div class="w-10 h-10 rounded-lg bg-evergreen/10 flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-evergreen" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                      </svg>
                    </div>
                    <div>
                      <h4 class="font-semibold text-sm text-black">{h.title}</h4>
                      <p class="text-slate-grey text-xs font-light mt-0.5">{h.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}

            <!-- Description -->
            {descriptionText && (
              <div class="mb-10 pb-10 border-b border-black/[0.08]" data-reveal>
                <h2 class="heading-md text-black text-xl mb-4">About this property</h2>
                {descriptionText.split('\n\n').map((paragraph: string) => (
                  <p class="text-black/70 text-[0.95rem] font-light leading-relaxed mb-4">{paragraph}</p>
                ))}
              </div>
            )}

            <!-- Amenities -->
            {property.amenities?.length > 0 && (
              <div class="mb-10 pb-10 border-b border-black/[0.08]" data-reveal>
                <h2 class="heading-md text-black text-xl mb-6">What this place offers</h2>
                <div class="grid sm:grid-cols-2 gap-x-12 gap-y-2">
                  {property.amenities.flatMap((group: any) =>
                    (group.items || []).map((item: any) => (
                      <div class="flex items-center gap-3 py-3 border-b border-black/[0.04]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-grey shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                        <span class="text-sm text-black/80">
                          {typeof item === 'string' ? item : item.name}
                          {item.note && <span class="text-slate-grey text-xs ml-1">({item.note})</span>}
                        </span>
                      </div>
                    ))
                  )}
                </div>
              </div>
            )}

            <!-- House Rules -->
            <div class="mb-10 pb-10 border-b border-black/[0.08]" data-reveal>
              <h2 class="heading-md text-black text-xl mb-6">House Rules</h2>
              <div class="grid sm:grid-cols-2 gap-4">
                {property.checkInTime && (
                  <div class="flex items-center gap-3 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>Check-in: <strong>{property.checkInTime}</strong></span>
                  </div>
                )}
                {property.checkOutTime && (
                  <div class="flex items-center gap-3 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>Check-out: <strong>{property.checkOutTime}</strong></span>
                  </div>
                )}
                {property.checkInMethod && (
                  <div class="flex items-center gap-3 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
                    <span>{checkInMethodLabels[property.checkInMethod] || property.checkInMethod}</span>
                  </div>
                )}
                {property.minNights && (
                  <div class="flex items-center gap-3 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    <span>Minimum {property.minNights} nights</span>
                  </div>
                )}
              </div>
              {property.houseRules?.length > 0 && (
                <div class="mt-6 space-y-2">
                  {property.houseRules.map((rule: any) => (
                    <div class="flex items-center gap-3 text-sm text-black/70">
                      <span class="w-1.5 h-1.5 rounded-full bg-marigold shrink-0"></span>
                      {typeof rule === 'string' ? rule : (ruleLabels[rule.rule] || rule.rule)}
                      {rule.details && <span class="text-slate-grey text-xs">— {rule.details}</span>}
                    </div>
                  ))}
                </div>
              )}
            </div>

            <!-- Reviews -->
            {property.reviewData && (
              <div class="mb-10" data-reveal>
                <div class="flex items-center gap-3 mb-6">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-marigold" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                  </svg>
                  <h2 class="heading-md text-black text-xl">
                    {property.reviewData.averageRating} &middot; {property.reviewData.totalReviews} reviews
                  </h2>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {property.reviewData.reviews.map((review: any) => (
                    <div class="p-5 rounded-2xl bg-white/50 border border-black/[0.04]">
                      <div class="flex items-center justify-between mb-3">
                        <div class="flex gap-0.5">
                          {Array.from({ length: 5 }).map((_, i) => (
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class={`w-3.5 h-3.5 ${i < review.rating ? 'text-marigold' : 'text-black/10'}`}
                              viewBox="0 0 24 24"
                              fill="currentColor"
                            >
                              <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                            </svg>
                          ))}
                        </div>
                        <div class="flex items-center gap-2">
                          <span class="text-xs text-slate-grey">{review.date}</span>
                          <span class="text-[0.6rem] text-slate-grey/60 uppercase tracking-wider">{review.platform}</span>
                        </div>
                      </div>
                      <p class="text-black/70 text-sm font-light leading-relaxed line-clamp-4">{review.text}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Right Column - Booking Sidebar (1/3) -->
          <div class="lg:col-span-1">
            <div class="sticky top-28">
              <div class="overflow-hidden" data-reveal>
                <!-- Hospitable Booking Widget -->
                {widget ? (
                  <div id="booking-widget">
                    <iframe
                      id="booking-iframe"
                      sandbox="allow-top-navigation allow-scripts allow-same-origin"
                      style="width: 100%; height: 900px; border: none; display: block;"
                      src={widget.iframe}
                    ></iframe>
                  </div>
                ) : (
                  <div class="p-6 text-center">
                    {property.basePrice && (
                      <div class="flex items-baseline justify-center gap-1 mb-4">
                        <span class="text-slate-grey text-sm font-normal">From </span>
                        <span class="text-2xl font-bold text-black">${property.basePrice}</span>
                        <span class="text-slate-grey text-sm font-light">/ night</span>
                      </div>
                    )}
                    <p class="text-slate-grey text-sm">Booking coming soon.</p>
                  </div>
                )}
              </div>

              <!-- Host Card -->
              {property.host && (
                <div class="rounded-2xl border border-black/[0.08] bg-white/70 p-6 mt-4" data-reveal>
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full bg-evergreen/15 flex items-center justify-center overflow-hidden">
                      <span class="text-evergreen font-bold text-lg">{(property.host as any).name?.[0] || 'H'}</span>
                    </div>
                    <div>
                      <h4 class="font-bold text-black">Hosted by {(property.host as any).name}</h4>
                    </div>
                  </div>
                  <button class="btn-outline !border-black/20 !text-black w-full justify-center mt-4 !py-3 !text-xs hover:!bg-black/5">
                    Contact Host
                  </button>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Nearby Attractions -->
    {property.nearbyAttractions?.length > 0 && (
      <section class="bg-evergreen py-16 lg:py-24 relative">
        <div class="absolute top-0 left-0 right-0 -translate-y-[99%]">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[60px] lg:h-[80px]">
            <path fill="#22382d" d="M0,20 C240,80 720,0 1080,50 C1260,70 1380,30 1440,40 L1440,80 L0,80 Z"></path>
          </svg>
        </div>

        <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
          <h2 class="heading-md text-white text-2xl mb-8" data-reveal>
            Nearby <span class="text-marigold italic">Attractions</span>
          </h2>
          <div class="grid sm:grid-cols-3 gap-4" data-stagger>
            {property.nearbyAttractions.map((attraction: any) => (
              <div class="rounded-xl bg-white/[0.06] border border-white/[0.08] p-5 hover:border-marigold/20 transition-all duration-300" data-reveal>
                <span class="label-sm text-marigold/60 block mb-2" style="font-size:0.6rem;">{attraction.type}</span>
                <h4 class="text-white font-semibold text-sm mb-1">{attraction.name}</h4>
                <p class="text-white/40 text-xs">{attraction.distance}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <Newsletter />
  </main>
  <Footer />

  <!-- Photo Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/95" id="lightbox-backdrop"></div>
    <div class="relative z-10 flex flex-col h-full">
      <!-- Header -->
      <div class="flex items-center justify-between px-6 py-4">
        <span id="lightbox-counter" class="text-white/70 text-sm font-medium"></span>
        <button id="lightbox-close" class="text-white/70 hover:text-white transition-colors p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <!-- Image -->
      <div class="flex-1 flex items-center justify-center px-16 pb-8 relative">
        <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
          </svg>
        </button>
        <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full object-contain rounded-lg" />
        <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <script>
    const grid = document.getElementById('photo-grid');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCounter = document.getElementById('lightbox-counter');
    const images: Array<{ src: string; alt: string }> = JSON.parse(grid?.dataset.images || '[]');
    let currentIndex = 0;

    function openLightbox(index: number) {
      currentIndex = index;
      updateLightbox();
      lightbox?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function updateLightbox() {
      if (!images[currentIndex]) return;
      lightboxImg.src = images[currentIndex].src;
      lightboxImg.alt = images[currentIndex].alt;
      if (lightboxCounter) {
        lightboxCounter.textContent = `${currentIndex + 1} / ${images.length}`;
      }
    }

    function nextPhoto() {
      currentIndex = (currentIndex + 1) % images.length;
      updateLightbox();
    }

    function prevPhoto() {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      updateLightbox();
    }

    // Grid photo clicks
    grid?.querySelectorAll('[data-photo-index]').forEach((el) => {
      el.addEventListener('click', () => {
        const index = parseInt(el.getAttribute('data-photo-index') || '0', 10);
        openLightbox(index);
      });
    });

    // Show all button
    document.getElementById('show-all-photos')?.addEventListener('click', (e) => {
      e.stopPropagation();
      openLightbox(0);
    });

    // Controls
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-backdrop')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-next')?.addEventListener('click', nextPhoto);
    document.getElementById('lightbox-prev')?.addEventListener('click', prevPhoto);

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lightbox?.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextPhoto();
      if (e.key === 'ArrowLeft') prevPhoto();
    });
  </script>

  <!-- Pass search params from Hospitable search widget to booking iframe -->
  <script>
    function getQueryParams(param: string): string | null {
      const urlSearchParams = new URLSearchParams(window.location.search);
      return urlSearchParams.get(param);
    }
    function updateIframeSrc() {
      const iframe = document.getElementById('booking-iframe') as HTMLIFrameElement | null;
      if (!iframe) return;
      const params: string[] = [];
      ['checkin', 'checkout', 'adults', 'children', 'infants', 'pets'].forEach((key) => {
        const val = getQueryParams(key);
        if (val) params.push(`${key}=${val}`);
      });
      if (params.length === 0) return;
      const sep = iframe.src.includes('?') ? '&' : '?';
      iframe.src = iframe.src + sep + params.join('&');
    }
    window.addEventListener('load', updateIframeSrc);
  </script>
</Layout>
