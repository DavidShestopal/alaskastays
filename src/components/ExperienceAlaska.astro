---
const experiences = [
  {
    title: 'Northern Lights',
    description: 'Chase the aurora borealis across Alaska\'s dark skies',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Glacier Hiking',
    description: 'Trek across ancient ice fields with expert guides',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-7.5L16.5 13.5m0 0L12 9m4.5 4.5V3" /></svg>`,
    span: '',
  },
  {
    title: 'Sport Fishing',
    description: 'World-class salmon and halibut fishing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>`,
    span: '',
  },
  {
    title: 'Wildlife Safaris',
    description: 'Bears, moose, eagles, and whales in their natural habitat',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    span: '',
  },
  {
    title: 'Dog Sledding',
    description: 'Race across frozen tundra with champion sled dogs',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Hot Springs',
    description: 'Soak in natural thermal pools under starlit skies',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/></svg>`,
    span: '',
  },
];
---

<section id="experiences" class="relative py-24 lg:py-36 bg-evergreen overflow-x-hidden">

  <!-- Dot decoration -->
  <div class="absolute bottom-16 right-10 w-24 h-24 dot-pattern opacity-15"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <div class="text-center mb-16 lg:mb-20" data-reveal>
      <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Things to Do</span>
      <h2 class="heading-lg text-white text-4xl lg:text-6xl">
        Experience the<br />
        <span class="text-marigold italic">Last Frontier.</span>
      </h2>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-5" data-stagger>
      {experiences.map((exp) => (
        <div
          class={`group relative rounded-2xl overflow-hidden cursor-pointer ${exp.span} min-h-[200px] lg:min-h-[220px] bg-white/[0.05] border border-white/[0.08] hover:border-marigold/20 transition-all duration-500`}
          data-reveal
        >
          <!-- Decorative circle -->
          <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full border border-white/[0.04] group-hover:border-marigold/10 transition-all duration-700 group-hover:scale-110"></div>

          <div class="relative h-full flex flex-col justify-end p-7 lg:p-8">
            <div class="text-marigold/50 mb-4 group-hover:text-marigold transition-colors duration-500">
              <Fragment set:html={exp.icon} />
            </div>
            <h3 class="font-sans font-bold text-2xl text-white mb-1.5 group-hover:text-marigold transition-colors duration-300">
              {exp.title}
            </h3>
            <p class="text-white/40 text-sm font-light leading-relaxed">
              {exp.description}
            </p>

            <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-marigold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>


</section>
