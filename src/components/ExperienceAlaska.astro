---
import { getExperiences } from '../lib/sanity';

const categoryLabels: Record<string, string> = {
  'northern-lights': 'Northern Lights', 'glacier': 'Tours', 'fishing': 'Fishing',
  'wildlife': 'Wildlife', 'dog-sledding': 'Dog Sledding', 'hiking': 'Hiking & Trekking',
  'water': 'Kayaking & Rafting', 'flightseeing': 'Flightseeing', 'hot-springs': 'Hot Springs',
  'cultural': 'Cultural', 'winter': 'Winter Sports', 'photography': 'Photography',
  'bear-viewing': 'Bear Viewing', 'whale-watching': 'Whale Watching',
  'city-tour': 'Tours', 'atv': 'ATV & Off-Road', 'biking': 'Biking',
  'climbing': 'Climbing', 'paddleboarding': 'Paddleboarding', 'elopement': 'Elopement & Wedding',
};

const sanityExperiences = await getExperiences() as any[];

const experiences = (sanityExperiences || []).map((exp: any) => ({
  slug: exp.slug,
  title: exp.title,
  tagline: exp.tagline,
  category: categoryLabels[exp.category] || exp.category,
  duration: exp.duration,
  coverImage: exp.coverImage?.asset?.url || exp.externalImageUrl,
  hasFareHarbor: !!(exp.fareHarborShortname && exp.fareHarborItemId),
})).slice(0, 6);

const hasExperiences = experiences.length > 0;
---

<section id="experiences" class="relative py-24 lg:py-36 bg-evergreen overflow-x-hidden">

  <!-- Dot decoration -->
  <div class="absolute bottom-16 right-10 w-24 h-24 dot-pattern opacity-15"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <div class="text-center mb-16 lg:mb-20" data-reveal>
      <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Things to Do</span>
      <h2 class="heading-lg text-white text-4xl lg:text-6xl">
        Experience the<br />
        <span class="text-marigold italic">Last Frontier.</span>
      </h2>
    </div>

    {hasExperiences ? (
      <!-- Experience Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6" data-stagger>
        {experiences.map((exp) => (
          <a
            href={`/experiences/${exp.slug}`}
            class="group relative rounded-2xl overflow-hidden min-h-[280px] lg:min-h-[320px] block"
            data-reveal
          >
            {/* Background image */}
            {exp.coverImage ? (
              <img src={exp.coverImage} alt={exp.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            ) : (
              <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-105" style="background: linear-gradient(135deg, #22382d 0%, #2e4d3d 100%);"></div>
            )}

            {/* Gradient overlay */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/5"></div>

            {/* Badges */}
            <div class="absolute top-4 left-4 flex gap-2">
              <span class="bg-marigold text-black text-xs font-bold px-3 py-1 rounded-full">{exp.category}</span>
            </div>

            {/* Duration badge */}
            {exp.duration && (
              <div class="absolute top-4 right-4">
                <span class="bg-black/40 backdrop-blur-sm text-white/90 text-xs font-medium px-3 py-1 rounded-full">{exp.duration}</span>
              </div>
            )}

            {/* Content */}
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="font-sans font-bold text-xl text-white mb-1.5 group-hover:text-marigold transition-colors duration-300">
                {exp.title}
              </h3>
              {exp.tagline && (
                <p class="text-white/70 text-sm leading-relaxed line-clamp-2">{exp.tagline}</p>
              )}
            </div>

            {/* Hover border */}
            <div class="absolute inset-0 rounded-2xl border-2 border-marigold/0 group-hover:border-marigold/30 transition-all duration-500 pointer-events-none"></div>
          </a>
        ))}
      </div>

      <!-- View All link -->
      <div class="text-center mt-12" data-reveal>
        <a href="/experiences" class="inline-flex items-center gap-2 text-marigold hover:text-white transition-colors duration-300 font-semibold text-sm tracking-wide uppercase">
          View All Experiences
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    ) : (
      <!-- Fallback: static bento grid when no Sanity data -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 text-center">
        <a href="/experiences" class="group relative rounded-2xl overflow-hidden min-h-[280px] flex items-center justify-center bg-white/[0.05] border border-white/[0.08] hover:border-marigold/20 transition-all duration-500" data-reveal>
          <div class="p-8">
            <h3 class="font-sans font-bold text-2xl text-white mb-2 group-hover:text-marigold transition-colors duration-300">Explore Adventures</h3>
            <p class="text-white/50 text-sm">Discover Alaska's most unforgettable experiences</p>
          </div>
        </a>
      </div>
    )}
  </div>

</section>
