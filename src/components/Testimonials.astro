---
import { getHomepageReviews } from '../lib/hospitable';

const reviews = await getHomepageReviews();
---

{reviews.length > 0 && (
<section class="relative py-24 lg:py-36 bg-evergreen overflow-x-hidden">
  <!-- Treeline divider top -->
  <div class="absolute top-0 left-0 right-0 -translate-y-[99%] pointer-events-none">
    <img src="/images/treeline-silhouette-dark.svg" alt="" role="presentation" class="w-full block" />
  </div>

  <!-- Dot decoration -->
  <div class="absolute top-16 left-10 w-20 h-20 dot-pattern opacity-15"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <div class="text-center mb-16 lg:mb-20" data-reveal>
      <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Guest Stories</span>
      <h2 class="heading-lg text-white text-4xl lg:text-5xl">
        What Our Guests<br />
        <span class="text-marigold italic">Are Saying...</span>
      </h2>
    </div>

    <!-- Slider -->
    <div class="relative" data-reveal>
      <!-- Navigation Arrows -->
      <button
        id="reviews-prev"
        class="absolute -left-4 lg:-left-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors border border-white/10"
        aria-label="Previous reviews"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
        </svg>
      </button>
      <button
        id="reviews-next"
        class="absolute -right-4 lg:-right-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors border border-white/10"
        aria-label="Next reviews"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
      </button>

      <!-- Slider Track -->
      <div id="reviews-track" class="overflow-hidden">
        <div id="reviews-slides" class="flex transition-transform duration-500 ease-out" style="gap: 1.5rem;">
          {reviews.map((review) => (
            <div
              class="review-slide flex-shrink-0 w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
            >
              <a
                href={`/properties/${review.propertySlug}`}
                class="group block relative rounded-2xl p-8 lg:p-10 border border-white/[0.08] hover:border-marigold/20 transition-all duration-500 bg-white/[0.04] h-full"
              >
                <!-- Decorative quote -->
                <div class="absolute top-6 right-8 font-serif text-[6rem] leading-none text-marigold/[0.08] pointer-events-none select-none">
                  &ldquo;
                </div>

                <!-- Stars -->
                <div class="flex gap-1 mb-5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class={`w-4 h-4 ${i < review.rating ? 'text-marigold' : 'text-white/10'}`}
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <blockquote class="text-white/70 text-[0.95rem] font-light leading-relaxed mb-8 relative z-10 line-clamp-5">
                  &ldquo;{review.text}&rdquo;
                </blockquote>

                <!-- Footer -->
                <div class="flex items-center justify-between mt-auto">
                  <span class="text-marigold/70 text-xs font-medium group-hover:text-marigold transition-colors">
                    {review.propertyName}
                  </span>
                  <div class="flex items-center gap-2">
                    <span class="text-white/30 text-xs">{review.date}</span>
                    <span class="text-white/20 text-[0.6rem] uppercase tracking-wider">{review.platform}</span>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots -->
      <div id="reviews-dots" class="flex justify-center gap-2 mt-8">
      </div>
    </div>
  </div>
</section>
)}

<script>
  const track = document.getElementById('reviews-slides');
  const container = document.getElementById('reviews-track');
  const prevBtn = document.getElementById('reviews-prev');
  const nextBtn = document.getElementById('reviews-next');
  const dotsContainer = document.getElementById('reviews-dots');
  if (!track || !container) throw new Error('missing slider elements');

  const slides = track.querySelectorAll('.review-slide');
  const totalSlides = slides.length;
  let currentPage = 0;
  const gap = 24; // 1.5rem

  function getVisibleCount(): number {
    const w = window.innerWidth;
    if (w >= 1024) return 3;
    if (w >= 640) return 2;
    return 1;
  }

  function getTotalPages(): number {
    return Math.max(1, totalSlides - getVisibleCount() + 1);
  }

  function getSlideWidth(): number {
    const visible = getVisibleCount();
    return (container!.offsetWidth - gap * (visible - 1)) / visible;
  }

  function updateSlider() {
    const slideWidth = getSlideWidth();
    const offset = currentPage * (slideWidth + gap);
    track!.style.transform = `translateX(-${offset}px)`;

    // Set slide widths
    slides.forEach((s) => {
      (s as HTMLElement).style.width = `${slideWidth}px`;
    });

    updateDots();
  }

  function updateDots() {
    if (!dotsContainer) return;
    const pages = getTotalPages();
    // Cap dots for readability
    const dotCount = Math.min(pages, totalSlides <= 6 ? pages : Math.ceil(totalSlides / getVisibleCount()));

    dotsContainer.innerHTML = '';
    for (let i = 0; i < dotCount; i++) {
      const dot = document.createElement('button');
      dot.className = `w-2 h-2 rounded-full transition-all duration-300 ${
        i === Math.min(currentPage, dotCount - 1)
          ? 'bg-marigold w-6'
          : 'bg-white/20 hover:bg-white/40'
      }`;
      dot.setAttribute('aria-label', `Go to slide group ${i + 1}`);
      dot.addEventListener('click', () => {
        currentPage = i;
        updateSlider();
      });
      dotsContainer.appendChild(dot);
    }
  }

  prevBtn?.addEventListener('click', () => {
    currentPage = Math.max(0, currentPage - 1);
    updateSlider();
  });

  nextBtn?.addEventListener('click', () => {
    const maxPage = getTotalPages() - 1;
    currentPage = Math.min(maxPage, currentPage + 1);
    updateSlider();
  });

  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  container?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  container?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        currentPage = Math.min(getTotalPages() - 1, currentPage + 1);
      } else {
        currentPage = Math.max(0, currentPage - 1);
      }
      updateSlider();
    }
  }, { passive: true });

  // Init & resize
  updateSlider();
  window.addEventListener('resize', () => {
    currentPage = Math.min(currentPage, getTotalPages() - 1);
    updateSlider();
  });
</script>
