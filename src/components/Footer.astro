      <!-- Link Columns -->
      <div>
        <h4 class="label-sm text-marigold/60 mb-5">Properties</h4>
        <ul class="space-y-3">
          {footerLinks.properties.map((link) => (
            <li>
              <a href={link.href} class="text-white/30 text-sm font-light hover:text-marigold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="label-sm text-marigold/60 mb-5">Experiences</h4>
        <ul class="space-y-3">
          {footerLinks.experiences.map((link) => (
            <li>
              <a href={link.href} class="text-white/30 text-sm font-light hover:text-marigold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="label-sm text-marigold/60 mb-5">Company</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-white/30 text-sm font-light hover:text-marigold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="label-sm text-marigold/60 mb-5">Support</h4>
        <ul class="space-y-3">
          {footerLinks.support.map((link) => (
            <li>
              <a href={link.href} class="text-white/30 text-sm font-light hover:text-marigold transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/[0.06] py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/20 text-xs">
        &copy; {currentYear} Alaska Stays. All rights reserved.
      </p>
      <p class="text-white/10 text-xs">
        Crafted with care in Anchorage, Alaska
      </p>
