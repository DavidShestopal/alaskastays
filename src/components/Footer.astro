---
const currentYear = new Date().getFullYear();

const footerLinks = {
  properties: [
    { label: 'All Properties', href: '/properties' },
    { label: 'Juniper Tree', href: '/properties/juniper-tree' },
    { label: 'Valley View', href: '/properties/valley-view' },
    { label: 'Book Your Stay', href: '/search' },
  ],
  experiences: [
    { label: 'Northern Lights', href: '/experiences' },
    { label: 'Glacier Tours', href: '/experiences' },
    { label: 'Sport Fishing', href: '/experiences' },
    { label: 'Wildlife Safaris', href: '/experiences' },
    { label: 'Dog Sledding', href: '/experiences' },
  ],
  company: [
    { label: 'About Us', href: '/about' },
    { label: 'Blog', href: '#' },
    { label: 'Contact', href: '/contact' },
    { label: 'FAQ', href: '/contact' },
    { label: 'Careers', href: '/contact' },
  ],
  support: [
    { label: 'Help Center', href: '/contact' },
    { label: 'Cancellation Policy', href: '#' },
    { label: 'Privacy Policy', href: '#' },
    { label: 'Terms of Service', href: '#' },
    { label: 'Accessibility', href: '#' },
  ],
};
