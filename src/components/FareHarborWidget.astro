---
interface Props {
  fareHarborShortname?: string;
  fareHarborItemId?: string;
  bookingUrl?: string;
  price?: number;
  priceNote?: string;
  partnerName?: string;
  duration?: string;
  difficulty?: string;
  groupSize?: { min: number; max: number };
  ratingScore?: number;
  ratingReviewCount?: number;
  ratingProvider?: string;
  calendarLink?: string;
  locationCity?: string;
}

const {
  fareHarborShortname,
  fareHarborItemId,
  bookingUrl,
  price,
  priceNote,
  partnerName,
  duration,
  difficulty,
  groupSize,
  ratingScore,
  ratingReviewCount,
  ratingProvider,
  calendarLink,
  locationCity,
} = Astro.props;

const affiliateId = import.meta.env.PUBLIC_FAREHARBOR_AFFILIATE_ID || '';
const hasFareHarbor = fareHarborShortname && fareHarborItemId;

// Build the calendar embed script URL from the calendarLink or construct it
const calendarScriptSrc = hasFareHarbor
  ? `https://fareharbor.com/embeds/script/calendar/${fareHarborShortname}/items/${fareHarborItemId}/?asn=fhdn&asn-ref=${affiliateId}&ref=${affiliateId}&bookable-only=yes&full-items=yes&marketplace=yes&flow=no`
  : null;
---

<div class="sticky top-28 space-y-4">
  <!-- Pricing & Partner Card -->
  <div class="rounded-2xl border border-black/[0.08] bg-white/70 p-6 shadow-lg shadow-black/5" data-reveal>
    {/* Rating */}
    {ratingScore && ratingScore > 0 && (
      <div class="flex items-center gap-2 mb-4">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class={`w-4 h-4 ${i < Math.round(ratingScore) ? 'text-marigold' : 'text-black/15'}`}
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
            </svg>
          ))}
        </div>
        <span class="text-sm font-semibold text-black">{ratingScore}</span>
        {ratingReviewCount && ratingReviewCount > 0 && (
          <span class="text-xs text-slate-grey">({ratingReviewCount.toLocaleString()} reviews)</span>
        )}
      </div>
    )}

    {partnerName && (
      <p class="text-black/50 text-xs mb-4">Operated by {partnerName}</p>
    )}

    <!-- Details -->
    <div class="space-y-3 text-sm border-t border-black/[0.08] pt-4 mb-5">
      {duration && (
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-black/80">Duration: <strong>{duration}</strong></span>
        </div>
      )}
      {groupSize && (
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          <span class="text-black/80">Group size: <strong>{groupSize.min}-{groupSize.max}</strong></span>
        </div>
      )}
      {difficulty && (
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          <span class="text-black/80">Difficulty: <strong>{difficulty}</strong></span>
        </div>
      )}
      {locationCity && (
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-grey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          <span class="text-black/80">Location: <strong>{locationCity}, Alaska</strong></span>
        </div>
      )}
    </div>

    {/* Fallback book button for non-FareHarbor or as quick CTA */}
    {!hasFareHarbor && bookingUrl ? (
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary w-full justify-center !py-4 !text-sm block text-center"
      >
        Book This Experience
      </a>
    ) : !hasFareHarbor && (
      <button class="btn-primary w-full justify-center !py-4 !text-sm opacity-60 cursor-not-allowed" disabled>
        Booking Coming Soon
      </button>
    )}
  </div>

  {/* FareHarbor Embedded Calendar */}
  {hasFareHarbor && (
    <div class="rounded-2xl border border-black/[0.08] bg-white/70 p-5 shadow-lg shadow-black/5 overflow-hidden" data-reveal>
      <h3 class="heading-md text-black text-base mb-3 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-marigold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
        </svg>
        Check Availability
      </h3>
      <p class="text-center text-slate-grey text-[10px] font-light mb-3">
        Secure booking powered by FareHarbor
      </p>
      <div id="fh-calendar-target" class="fh-calendar-embed">
        {/* Calendar embed script — FareHarbor injects the calendar right after this script tag */}
        <script src={calendarScriptSrc} is:inline></script>
      </div>
    </div>
  )}
</div>

<style is:global>
  /* Ensure FareHarbor calendar wrap stays inside our container */
  #fh-calendar-target {
    position: relative;
  }
  #fh-calendar-target .fareharbor-calendar-wrap {
    position: relative !important;
    width: 100% !important;
  }
  #fh-calendar-target .fareharbor-calendar-wrap iframe {
    width: 100% !important;
    border-radius: 0.75rem !important;
    border: none !important;
  }

  /* FareHarbor calendar embed overrides */
  .fh-calendar-embed .fh-container {
    font-family: inherit !important;
  }
  .fh-calendar-embed .fh-cal {
    border: none !important;
    border-radius: 0.75rem !important;
    overflow: hidden !important;
  }
  .fh-calendar-embed .fh-cal__nav {
    background: #2f6e60 !important;
    color: white !important;
    border-radius: 0.75rem 0.75rem 0 0 !important;
  }
  .fh-calendar-embed .fh-cal__nav-btn {
    color: white !important;
  }
  .fh-calendar-embed .fh-cal__day--avail {
    background: #f0faf6 !important;
    color: #2f6e60 !important;
    font-weight: 600 !important;
    border-radius: 0.375rem !important;
  }
  .fh-calendar-embed .fh-cal__day--avail:hover {
    background: #2f6e60 !important;
    color: white !important;
  }
  .fh-calendar-embed .fh-cal__day--selected {
    background: #dbb876 !important;
    color: #1a1a1a !important;
  }
  .fh-calendar-embed .fh-cal__day--today {
    border: 2px solid #dbb876 !important;
  }
  .fh-calendar-embed .fh-button,
  .fh-calendar-embed .fh-btn {
    background: #dbb876 !important;
    color: #1a1a1a !important;
    border: none !important;
    border-radius: 9999px !important;
    font-weight: 600 !important;
  }
  .fh-calendar-embed .fh-button:hover,
  .fh-calendar-embed .fh-btn:hover {
    background: #c9a85e !important;
  }
</style>
