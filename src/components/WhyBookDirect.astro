---
const benefits = [
  {
    title: 'Best Price Guarantee',
    description: 'Book direct and save 10-20% compared to third-party platforms. No hidden fees, no service charges.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: 'Flexible Cancellation',
    description: 'Plans change, we understand. Enjoy free cancellation up to 48 hours before your arrival date.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>`,
  },
  {
    title: 'Local Concierge',
    description: 'Our Alaska-based team crafts personalized itineraries and is available around the clock during your stay.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
  },
  {
    title: 'Authentic Experiences',
    description: 'Every property is owner-operated with deep roots in Alaska. Real hospitality, not corporate stays.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
  },
];
---

<section id="about" class="relative py-24 lg:py-36 bg-river-rock overflow-hidden">
  <!-- Dot decoration -->
  <div class="absolute top-20 left-10 w-16 h-16 dot-pattern opacity-15"></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <div class="text-center mb-16 lg:mb-20" data-reveal>
      <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Why Book Direct</span>
      <h2 class="heading-lg text-black text-4xl lg:text-5xl max-w-2xl mx-auto">
        The Alaska Stays<br />
        <span class="text-marigold italic">Difference.</span>
      </h2>
    </div>

    <!-- Benefits Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8" data-stagger>
      {benefits.map((benefit) => (
        <div class="group text-center lg:text-left bg-white/40 rounded-2xl p-8 hover:bg-white/70 transition-all duration-500" data-reveal>
          <!-- Icon -->
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-evergreen/10 text-evergreen mb-6 group-hover:bg-marigold/15 group-hover:text-marigold transition-all duration-500">
            <Fragment set:html={benefit.icon} />
          </div>

          <h3 class="font-sans font-bold text-xl text-black mb-3">{benefit.title}</h3>
          <p class="text-slate-grey text-sm font-light leading-relaxed">{benefit.description}</p>

          <div class="w-8 h-[2px] bg-marigold/40 mt-6 mx-auto lg:mx-0 group-hover:w-16 transition-all duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>
