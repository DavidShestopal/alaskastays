---
import { getFeaturedProperties } from '../lib/hospitable';

const properties = await getFeaturedProperties();
---

{properties.length > 0 && (
<section id="properties" class="relative py-24 lg:py-36 bg-river-rock overflow-hidden">
  <!-- Dot pattern decoration -->
  <div class="absolute top-16 right-12 w-20 h-20 dot-pattern opacity-20"></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section Header (figtitle style: bold with marigold accent words) -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20" data-reveal>
      <div>
        <span class="label-sm text-marigold tracking-[0.2em] mb-4 block">Featured Properties</span>
        <h2 class="heading-lg text-black text-4xl lg:text-6xl">
          Handpicked<br />
          <span class="text-marigold italic">Retreats.</span>
        </h2>
      </div>
      <p class="text-charcoal text-[0.95rem] font-normal max-w-md mt-6 lg:mt-0 leading-relaxed">
        Each property is personally vetted for quality, location, and that
        unmistakable sense of Alaskan magic.
      </p>
    </div>

    <!-- Property Grid -->
    <div class="grid lg:grid-cols-2 gap-5 lg:gap-6">
      {properties.map((property, index) => (
        <a
          href={`/properties/${property.slug}`}
          class="group relative rounded-3xl overflow-hidden cursor-pointer min-h-[500px] lg:min-h-[640px] bg-evergreen block"
          data-reveal-scale
        >
          {property.coverImage ? (
            <img
              src={property.coverImage}
              alt={property.title}
              width="750"
              height="500"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="eager"
            />
          ) : (
            <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
              style="background: linear-gradient(135deg, #2e4d3d 0%, #22382d 40%, #1a2b22 100%);"></div>
          )}

          <!-- Decorative circles -->
          <div class="absolute top-8 right-8 w-24 h-24 border border-white/[0.06] rounded-full"></div>
          <div class="absolute top-12 right-12 w-16 h-16 border border-marigold/10 rounded-full"></div>

          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

          <div class="relative h-full flex flex-col justify-between p-8 lg:p-10">
            <div class="flex items-center justify-between">
              <span class="text-white/80 text-sm font-medium">
                {property.bedrooms} bed &middot; {property.guests} guests
              </span>
            </div>

            <div>
              <p class="text-white/80 text-sm mb-2">{property.tagline}</p>
              <h3 class="font-sans font-bold text-3xl lg:text-4xl text-white mb-2">{property.title}</h3>
              <div class="flex items-center justify-between mt-4">
                <div class="flex items-center gap-3">
                  <span class="text-white/80 text-sm font-medium">{property.location}</span>
                  {property.rating && (
                    <span class="flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-marigold" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"/>
                      </svg>
                      <span class="text-white text-sm font-semibold">{property.rating}</span>
                      <span class="text-white/60 text-xs">({property.totalReviews})</span>
                    </span>
                  )}
                </div>
                {property.basePrice && (
                  <span class="text-marigold font-bold text-lg">
                    <span class="text-white/70 text-sm font-normal">From </span>${property.basePrice}<span class="text-white/70 text-sm font-normal">/night</span>
                  </span>
                )}
              </div>

              <div class="mt-6 overflow-hidden h-0 group-hover:h-12 transition-all duration-500">
                <span class="btn-primary w-full justify-center !py-3 !text-xs">
                  View Property
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </div>

          <div class="absolute inset-0 rounded-3xl border-2 border-marigold/0 group-hover:border-marigold/30 transition-all duration-500 pointer-events-none"></div>
        </a>
      ))}
    </div>

    <!-- View All Link -->
    <div class="text-center mt-12 lg:mt-16" data-reveal>
      <a href="/properties" class="btn-dark">
        View All Properties
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
)}
