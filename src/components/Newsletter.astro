<section class="relative py-24 lg:py-32 overflow-hidden bg-evergreen">
  <div class="relative max-w-2xl mx-auto px-6 lg:px-10 text-center" data-reveal>
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full border border-marigold/30 mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-marigold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>

    <h2 class="heading-lg text-white text-3xl lg:text-5xl mb-4">
      Stay Connected<br />
      <span class="text-marigold italic">to the Wild.</span>
    </h2>
    <p class="text-white/40 text-[0.95rem] font-light mb-10 max-w-md mx-auto leading-relaxed">
      Seasonal availability, new properties, aurora forecasts, and exclusive offers delivered to your inbox.
    </p>

    <!-- Email Form -->
    <form id="newsletter-form" action="https://formspree.io/f/xaqdzoob" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
      <div class="flex-1">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="w-full px-6 py-4 rounded-full bg-white/[0.08] border border-white/[0.1] text-white placeholder-white/25 text-[0.9rem] font-light outline-none focus:border-marigold/40 focus:bg-white/[0.1] transition-all duration-300"
        />
      </div>
      <button type="submit" class="btn-primary !py-4 !px-8 whitespace-nowrap">
        Subscribe
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <p id="newsletter-success" class="text-marigold text-sm mt-5 hidden">Thanks for subscribing! We'll be in touch.</p>
    <p id="newsletter-error" class="text-red-400 text-sm mt-5 hidden">Something went wrong. Please try again.</p>
    <p id="newsletter-note" class="text-white/20 text-xs mt-5">No spam, unsubscribe anytime. We respect your inbox.</p>

    <script>
      document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button[type="submit"]');
        const btnText = btn.innerHTML;
        btn.innerHTML = 'Sending...';
        btn.disabled = true;

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' },
          });
          if (res.ok) {
            form.classList.add('hidden');
            document.getElementById('newsletter-note')?.classList.add('hidden');
            document.getElementById('newsletter-success')?.classList.remove('hidden');
          } else {
            document.getElementById('newsletter-error')?.classList.remove('hidden');
            btn.innerHTML = btnText;
            btn.disabled = false;
          }
        } catch {
          document.getElementById('newsletter-error')?.classList.remove('hidden');
          btn.innerHTML = btnText;
          btn.disabled = false;
        }
      });
    </script>
  </div>
</section>
